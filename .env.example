# FounderForge Replit Environment / Secrets
# Replit stores these in the Secrets tool and exposes them to the app at runtime.

# NextAuth Configuration
# Replit dev URL example: https://your-repl-id.worf.replit.dev
# Production URL example: https://your-domain-or-replit-app-url
NEXTAUTH_URL=https://your-repl-url
NEXTAUTH_SECRET=your-random-secret-here

# Replit PostgreSQL
# Created automatically when you install the PostgreSQL tool in Replit.
DATABASE_URL=postgresql://user:password@host:port/database

# Google OAuth
# Add this callback in Google Cloud Console:
# https://your-repl-url/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Anthropic API
ANTHROPIC_API_KEY=your-anthropic-api-key

# YouTube Data API (for Idea Discovery track)
YOUTUBE_API_KEY=your-youtube-api-key-here

# Admin Configuration
# Comma-separated list of admin email addresses.
ADMIN_EMAILS=admin@example.com,founder@example.com
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com,founder@example.com
