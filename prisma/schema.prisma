// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
}

// User model - linked to NextAuth
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  projects               Project[]
  personality            Personality?
  memory                 Memory?
  activities             Activity[]
  stats                  UserStats?
  achievements           UserAchievement[]
  leaderboardEntries     LeaderboardEntry[]
  founderProfile         FounderProfile?
  sentConnections        Connection[]        @relation("ConnectionRequester")
  receivedConnections    Connection[]        @relation("ConnectionReceiver")
  sentMessages           DirectMessage[]     @relation("DMSender")
  receivedMessages       DirectMessage[]     @relation("DMReceiver")
  // Forums
  postsAuthored          Post[]              @relation("PostAuthor")
  postVotes              PostVote[]          @relation("PostVoter")
  commentsAuthored       Comment[]           @relation("CommentAuthor")
  // Group rooms
  roomsCreated           GroupRoom[]         @relation("RoomCreator")
  roomMemberships        GroupMembership[]   @relation("RoomMember")
  groupMessages          GroupMessage[]      @relation("RoomMessageSender")
  // Feed
  feedPosts              FeedPost[]          @relation("FeedPostAuthor")
  feedReactions          FeedReaction[]      @relation("FeedReactor")
  feedComments           FeedComment[]       @relation("FeedCommentAuthor")
  // Discovery
  discoveredProblems     DiscoveredProblem[]
  // 90 Days at YC
  ycPrograms             YCProgram[]
  // Expert Hire
  expertSprints          ExpertSprint[]

  @@index([email])
}

// Project model - user's startup projects
model Project {
  id              String   @id @default(cuid())
  name            String
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  completedTasks  Json     @default("{}") // {stepId: completedCount}
  deliverables    Json     @default("{}") // {taskId: deliverableText}
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  conversations   Conversation[]
  
  @@index([userId])
}

// Conversation model - task-specific message threads
model Conversation {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId      String   // e.g., "1.1", "2.3"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  messages    Message[]
  
  @@unique([projectId, taskId])
  @@index([projectId])
}

// Message model - individual messages in conversations
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  role           String       // "user" or "assistant"
  content        String       @db.Text
  
  createdAt      DateTime     @default(now())
  
  @@index([conversationId])
}

// Personality model - user's personality assessment
model Personality {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  workStyle   String?  // methodical, iterative, creative, analytical
  experience  String?  // first-timer, side-hustler, serial, corporate
  motivation  String?  // problem-solver, freedom-seeker, impact-driven, wealth-builder
  learning    String?  // by-doing, by-example, by-theory, by-discussion
  pace        String?  // sprint, marathon, bursts, deliberate
  
  completed   Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Memory model - user's memory and context
model Memory {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  profile     Json     @default("{}") // {goals: [], challenges: [], strengths: [], preferences: [], background: null}
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastActive  DateTime @default(now())
  
  // Relations
  insights    Insight[]
  milestones  Milestone[]
  decisions   Decision[]
  patterns    Pattern[]
  sessions    Session[]
}

// Insight model - captured insights
model Insight {
  id         String   @id @default(cuid())
  memoryId   String
  memory     Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  
  content    String   @db.Text
  context    Json?    // {task, projectId, importance}
  importance String   @default("normal") // normal, high
  
  createdAt  DateTime @default(now())
  
  @@index([memoryId])
}

// Milestone model - achievements
model Milestone {
  id         String   @id @default(cuid())
  memoryId   String
  memory     Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  
  milestone  String
  projectId  String?
  celebrated Boolean  @default(false)
  
  createdAt  DateTime @default(now())
  
  @@index([memoryId])
}

// Decision model - key decisions made
model Decision {
  id         String   @id @default(cuid())
  memoryId   String
  memory     Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  
  decision   String   @db.Text
  reasoning  String   @db.Text
  projectId  String?
  outcome    String?  @db.Text
  
  createdAt  DateTime @default(now())
  
  @@index([memoryId])
}

// Pattern model - recurring patterns
model Pattern {
  id         String   @id @default(cuid())
  memoryId   String
  memory     Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  
  type       String   // stickingPoints, successPatterns, commonQuestions
  pattern    String   @db.Text
  frequency  Int      @default(1)
  
  firstSeen  DateTime @default(now())
  lastSeen   DateTime @default(now())
  
  @@index([memoryId, type])
}

// Session model - session summaries
model Session {
  id            String   @id @default(cuid())
  memoryId      String
  memory        Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  
  duration      Int?     // in minutes
  tasksCompleted Json    @default("[]")
  keyPoints     Json     @default("[]")
  nextSteps     Json     @default("[]")
  mood          String?  // productive, struggling, confident, etc.
  
  createdAt     DateTime @default(now())
  
  @@index([memoryId])
}

// Activity model - user activity tracking for admin
model Activity {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type       String   // message, task_complete, project_created, etc.
  projectId  String?
  stage      Int?
  task       String?
  details    Json?
  
  createdAt  DateTime @default(now())
  
  @@index([userId, createdAt])
  @@index([type])
}

// UserStats model - gamification statistics
model UserStats {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  xp              Int      @default(0)
  level           Int      @default(1)
  points          Int      @default(0)
  streak          Int      @default(0)
  lastActiveDate  DateTime @default(now())
  
  tasksCompleted  Int      @default(0)
  totalTimeSpent  Int      @default(0) // in minutes
  averageSpeed    Float    @default(0)
  perfectDays     Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([xp])
  @@index([level])
}

// Achievement model - available achievements
model Achievement {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  icon        String
  category    String   // speed, consistency, quality, milestone
  requirement Json     // {type: "tasks", value: 10} or {type: "streak", value: 7}
  xpReward    Int      @default(50)
  
  users       UserAchievement[]
  
  createdAt   DateTime @default(now())
}

// UserAchievement model - achievements earned by users
model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  
  earnedAt      DateTime    @default(now())
  celebrated    Boolean     @default(false)
  
  @@unique([userId, achievementId])
  @@index([userId])
}

// LeaderboardEntry model - weekly/monthly leaderboard snapshots
model LeaderboardEntry {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  period     String   // "week_2024_01" or "month_2024_01"
  xpEarned   Int
  rank       Int
  
  createdAt  DateTime @default(now())
  
  @@unique([userId, period])
  @@index([period, rank])
  @@index([userId])
}

// AdminSession model - admin authentication sessions
model AdminSession {
  id         String   @id @default(cuid())
  token      String   @unique

  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([token])
}

// ── Social / Community models ──

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// Community profile founders opt into for discovery
model FounderProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio           String?  @db.Text
  linkedIn      String?
  twitter       String?
  website       String?
  openToConnect Boolean  @default(true)
  lookingFor    String[] // e.g. ["peer", "co-founder", "advisor"]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Peer connection requests between founders
model Connection {
  id          String           @id @default(cuid())
  requesterId String
  requester   User             @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User             @relation("ConnectionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  status      ConnectionStatus @default(PENDING)
  message     String?          @db.Text

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([requesterId, receiverId])
  @@index([requesterId])
  @@index([receiverId])
}

// Async direct messages between connected founders
model DirectMessage {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("DMSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("DMReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  read       Boolean  @default(false)

  createdAt  DateTime @default(now())

  @@index([senderId, receiverId])
  @@index([receiverId, read])
}

// ── Forums (Reddit-style) ────────────────────────────────────────────────────

model Channel {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  type        String   // "curriculum" | "topic"
  order       Int      @default(0)
  posts       Post[]
  createdAt   DateTime @default(now())
}

model Post {
  id           String     @id @default(cuid())
  channelId    String
  channel      Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId     String
  author       User       @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  title        String
  body         String     @db.Text
  voteScore    Int        @default(0)
  commentCount Int        @default(0)
  votes        PostVote[]
  comments     Comment[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([channelId, createdAt])
  @@index([channelId, voteScore])
  @@index([authorId])
}

model PostVote {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("PostVoter", fields: [userId], references: [id], onDelete: Cascade)
  value  Int    // 1 or -1

  @@unique([postId, userId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([authorId])
}

// ── Group Rooms (async group chat) ───────────────────────────────────────────

enum MemberRole {
  ADMIN
  MEMBER
}

model GroupRoom {
  id          String            @id @default(cuid())
  name        String
  description String?
  isPublic    Boolean           @default(true)
  creatorId   String
  creator     User              @relation("RoomCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  members     GroupMembership[]
  messages    GroupMessage[]
  createdAt   DateTime          @default(now())

  @@index([isPublic])
  @@index([creatorId])
}

model GroupMembership {
  id       String     @id @default(cuid())
  roomId   String
  room     GroupRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation("RoomMember", fields: [userId], references: [id], onDelete: Cascade)
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

model GroupMessage {
  id        String    @id @default(cuid())
  roomId    String
  room      GroupRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User      @relation("RoomMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  content   String    @db.Text
  createdAt DateTime  @default(now())

  @@index([roomId, createdAt])
}

// ── Feed (LinkedIn-style) ────────────────────────────────────────────────────

model FeedPost {
  id        String         @id @default(cuid())
  authorId  String
  author    User           @relation("FeedPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body      String         @db.Text
  milestone String?        // e.g. "Completed: Problem Hypothesis"
  taskId    String?
  stepId    Int?
  reactions FeedReaction[]
  comments  FeedComment[]
  createdAt DateTime       @default(now())

  @@index([authorId, createdAt])
  @@index([createdAt])
}

model FeedReaction {
  id         String   @id @default(cuid())
  feedPostId String
  feedPost   FeedPost @relation(fields: [feedPostId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("FeedReactor", fields: [userId], references: [id], onDelete: Cascade)
  type       String   // "like" | "celebrate" | "insightful"

  @@unique([feedPostId, userId])
  @@index([feedPostId])
}

model FeedComment {
  id         String   @id @default(cuid())
  feedPostId String
  feedPost   FeedPost @relation(fields: [feedPostId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation("FeedCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body       String   @db.Text
  createdAt  DateTime @default(now())

  @@index([feedPostId])
}

// ── Idea Discovery Track ──────────────────────────────────────────────────────

model Domain {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  icon        String
  keywords    String[]
  videos      DomainVideo[]
  createdAt   DateTime      @default(now())
}

model DomainVideo {
  id                 String              @id @default(cuid())
  youtubeId          String              @unique
  title              String
  description        String?             @db.Text
  thumbnailUrl       String?
  channelTitle       String?
  domainId           String
  domain             Domain              @relation(fields: [domainId], references: [id], onDelete: Cascade)
  transcript         String?             @db.Text
  extractedProblems  Json?
  transcriptCachedAt DateTime?
  problems           DiscoveredProblem[]
  createdAt          DateTime            @default(now())

  @@index([domainId])
}

model DiscoveredProblem {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId     String?
  video       DomainVideo? @relation(fields: [videoId], references: [id], onDelete: SetNull)
  domainId    String?
  problemText String       @db.Text
  notes       String?      @db.Text
  graduated   Boolean      @default(false)
  projectId   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
}

// ── 90 Days at YC ─────────────────────────────────────────────────────────────

model YCProgram {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startupName     String
  oneLiner        String   @db.Text
  stage           String   // "idea" | "building" | "launched" | "revenue"
  startingRevenue Int      @default(0)        // monthly revenue at start, USD
  targetRevenue   Int      @default(1000000)  // annual run-rate goal, USD
  durationDays    Int      @default(90)       // sprint length chosen by the founder
  currentDay      Int      @default(1)
  status          String   @default("active") // "planning" | "active" | "completed" | "abandoned"
  phases          Json?    // [{name, dayStart, dayEnd, goal, milestone}]
  planDays        Json?    // draft skeleton [{day, theme, objective}] while status = "planning"
  planChat        Json?    // [{role, content}] plan-refinement conversation
  partnerName     String   @default("Michael Seibel")
  startDate       DateTime @default(now())
  days            YCDay[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model YCDay {
  id          String    @id @default(cuid())
  programId   String
  program     YCProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  dayNumber   Int
  theme       String
  objective   String    @db.Text
  tasks       Json      @default("[]")  // [{text, done}]
  partnerNote String?   @db.Text
  rationale   String?   @db.Text
  detailed    Boolean   @default(false)
  status      String    @default("pending") // "pending" | "active" | "done"
  report      Json?     // {summary, blockers, revenue, users, mood}
  reportedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@unique([programId, dayNumber])
  @@index([programId])
}

// ── Expert Hire Sprints ────────────────────────────────────────────────────────

model ExpertSprint {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String           // "marketing"|"sales"|"engineering"|"design"|"finance"|"ops"|"growth"|"custom"
  roleName       String           // e.g. "Head of Marketing"
  expertName     String           // AI persona first name
  goal           String           @db.Text
  timeline       Int              // sprint length in days (7, 14, 30, 60, 90)
  startupContext String?          @db.Text
  currentDay     Int              @default(1)
  status         String           @default("active") // "active"|"completed"|"abandoned"
  phases         Json?
  days           ExpertSprintDay[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([userId])
}

model ExpertSprintDay {
  id          String       @id @default(cuid())
  sprintId    String
  sprint      ExpertSprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  dayNumber   Int
  theme       String
  objective   String       @db.Text
  tasks       Json         @default("[]")  // [{text, done}]
  expertNote  String?      @db.Text
  rationale   String?      @db.Text
  detailed    Boolean      @default(false)
  status      String       @default("pending") // "pending"|"active"|"done"
  report      Json?        // {summary, blockers, metric, mood, feedback}
  reportedAt  DateTime?
  createdAt   DateTime     @default(now())

  @@unique([sprintId, dayNumber])
  @@index([sprintId])
}
